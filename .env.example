# GitHub OAuth App credentials
# Register OAuth app at: https://github.com/settings/developers
# Authorization callback URL should be: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=Iv23li_xxxxxxxxx
GITHUB_CLIENT_SECRET=gho_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL for OAuth redirect (optional, defaults to request origin)
# Only needed if frontend is on different origin than backend
# FRONTEND_URL=http://localhost:5173

# Port for the Express backend (default: 3001)
PORT=3001
